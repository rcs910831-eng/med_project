# ================================================================
# SHIELD PHARMA-HYBRID v21.0 & PHARMA-MOBILE v3.0
# Environment Configuration Template
# ================================================================
# 🔐 SECURITY: Never commit .env with real keys to Git!
# Copy this file to .env and fill in your actual API keys
# ================================================================

# --- Anthropic Claude API ---
# Get from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-your-actual-key-here

# --- Google Cloud APIs ---
# Get from: https://console.cloud.google.com/apis/credentials
# Required for: Google Places (pharmacy search), Google Maps
GOOGLE_API_KEY=your-google-api-key-here

# --- Kakao APIs (Korean services) ---
# Get from: https://developers.kakao.com/
KAKAO_REST_API_KEY=your-kakao-rest-api-key-here
KAKAO_ACCESS_TOKEN=your-kakao-access-token-here
KAKAO_REFRESH_TOKEN=your-kakao-refresh-token-here

# --- MFDS (Ministry of Food and Drug Safety) ---
# Get from: https://www.data.go.kr/
# Korean drug information database
MFDS_API_KEY=your-mfds-api-key-here

# --- Pharmacy Stock & Drug Info ---
# 의약품 재고 및 약가 정보
DRUG_STOCK_API_KEY=your-drug-stock-api-key-here

# --- Public Data API ---
# Korean government open data API
PUBLIC_DATA_API_KEY=your-public-data-api-key-here

# ================================================================
# Development Settings
# ================================================================
DEBUG=false
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///pharma_mobile.db

# Flask/FastAPI Configuration
FLASK_ENV=production
PYTHONUNBUFFERED=1
