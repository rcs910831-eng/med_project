# PHARMA-MOBILE Backend Environment Variables
# .env 파일로 복사하여 실제 값 입력

# API 설정
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# AI/LLM
GEMINI_API_KEY=your_gemini_api_key_here

# 데이터베이스
DATABASE_URL=sqlite:///pharma_mobile.db
# PostgreSQL의 경우:
# DATABASE_URL=postgresql://user:password@localhost:5432/pharma_mobile

# 보안
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 로깅
LOG_LEVEL=INFO
LOG_FILE=logs/pharma_backend.log

# 외부 API
GOOGLE_CLOUD_PROJECT=your_project_id
GOOGLE_SPEECH_CREDENTIALS=path/to/credentials.json

# 모니터링
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id

# 환경
ENVIRONMENT=development
DEBUG=True
